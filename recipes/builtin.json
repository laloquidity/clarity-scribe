[
  {
    "id": "spotify.play",
    "describe": "Search Spotify and play the top result",
    "verified": "2026-07-21 on Spotify desktop (Windows)",
    "patterns": [
      "play {query} on spotify",
      "open spotify and play {query}",
      "spotify play {query}"
    ],
    "slots": ["query"],
    "source": "builtin",
    "steps": [
      { "action": "deeplink", "uri": "spotify:search:{{query}}" },
      { "action": "waitFor", "target": { "nameFromSlot": "query" }, "timeoutMs": 15000 },
      { "action": "click", "target": { "name": "Play", "type": "Button", "invokable": true } }
    ]
  },
  {
    "id": "youtube.search",
    "describe": "Search YouTube in the browser",
    "verified": "URL only — no UI automation involved",
    "patterns": [
      "search youtube for {query}",
      "youtube {query}",
      "find {query} on youtube"
    ],
    "slots": ["query"],
    "source": "builtin",
    "steps": [
      { "action": "deeplink", "uri": "https://www.youtube.com/results?search_query={{query}}" }
    ]
  },
  {
    "id": "maps.directions",
    "describe": "Open directions in the browser",
    "verified": "URL only — no UI automation involved",
    "patterns": [
      "directions to {destination}",
      "navigate to {destination}",
      "how do i get to {destination}"
    ],
    "slots": ["destination"],
    "source": "builtin",
    "steps": [
      { "action": "deeplink", "uri": "https://www.google.com/maps/dir/?api=1&destination={{destination}}" }
    ]
  }
]
